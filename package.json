{
  "name": "nktc-app-monorepo",
  "version": "1.0.1",
  "private": true,
  "description": "NKTC Student Management System - Monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:stream": "turbo run dev --ui=stream",
    "dev:tui": "turbo run dev --ui=tui",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "dev:frontend": "turbo run dev --filter=nktc-app",
    "dev:backend": "turbo run dev --filter=backend-elysia",
    "build:frontend": "turbo run build --filter=nktc-app",
    "build:backend": "turbo run build --filter=backend-elysia",
    "dev:all": "turbo run dev",
    "deploy:x86": "bash ./deploy/deploy.sh x86 deploy",
    "deploy:pi4": "bash ./deploy/deploy.sh pi4 deploy",
    "deploy:x86:build": "bash ./deploy/deploy.sh x86 build",
    "deploy:pi4:build": "bash ./deploy/deploy.sh pi4 build",
    "deploy:x86:migrate": "bash ./deploy/deploy.sh x86 migrate",
    "deploy:pi4:migrate": "bash ./deploy/deploy.sh pi4 migrate",
    "deploy:x86:up": "bash ./deploy/deploy.sh x86 up",
    "deploy:pi4:up": "bash ./deploy/deploy.sh pi4 up",
    "deploy:x86:down": "bash ./deploy/deploy.sh x86 down",
    "deploy:pi4:down": "bash ./deploy/deploy.sh pi4 down"
  },
  "devDependencies": {
    "turbo": "^2.9.3"
  },
  "packageManager": "bun@1.3.3",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "workspaces": [
    "frontend",
    "backend-elysia"
  ],
  "dependencies": {
    "body-parser": "^2.2.2",
    "esbuild": "^0.25.12",
    "happy-dom": "^20.8.9",
    "minio": "^8.0.7",
    "validator": "^13.15.35",
    "vitest": "^4.1.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6"
  },
  "resolutions": {
    "happy-dom": "^20.0.8",
    "esbuild": "^0.25.11",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "tmp": "^0.2.5"
  }
}
