{
  "name": "nktc-app-monorepo",
  "version": "1.0.5",
  "private": true,
  "description": "NKTC Student Management System - Monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "pr": "bun ./scripts/pr.ts",
    "pr:create": "bun ./scripts/pr.ts --create",
    "dev:stream": "turbo run dev --ui=stream",
    "dev:tui": "turbo run dev --ui=tui",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage --filter=backend-elysia",
    "clean": "turbo run clean",
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:backend": "turbo run dev --filter=backend-elysia",
    "build:frontend": "turbo run build --filter=nktc-app",
    "build:backend": "turbo run build --filter=backend-elysia",
"deploy:x86": "bash ./deploy/deploy.sh x86 deploy",
    "deploy:pi4": "bash ./deploy/deploy.sh pi4 deploy",
    "deploy:x86:build": "bash ./deploy/deploy.sh x86 build",
    "deploy:pi4:build": "bash ./deploy/deploy.sh pi4 build",
    "deploy:x86:migrate": "bash ./deploy/deploy.sh x86 migrate",
    "deploy:pi4:migrate": "bash ./deploy/deploy.sh pi4 migrate",
    "deploy:x86:up": "bash ./deploy/deploy.sh x86 up",
    "deploy:pi4:up": "bash ./deploy/deploy.sh pi4 up",
    "deploy:x86:down": "bash ./deploy/deploy.sh x86 down",
    "deploy:pi4:down": "bash ./deploy/deploy.sh pi4 down",
    "version:status": "bun ./scripts/bump.ts",
    "version:patch": "bun ./scripts/bump.ts patch",
    "version:minor": "bun ./scripts/bump.ts minor",
    "version:major": "bun ./scripts/bump.ts major",
    "version:set": "bun ./scripts/bump.ts set"
  },
  "devDependencies": {
    "turbo": "^2.9.16"
  },
  "packageManager": "bun@1.3.3",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "workspaces": [
    "frontend",
    "backend-elysia"
  ],
  "dependencies": {
    "body-parser": "^2.2.2",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.9.0",
    "minio": "^8.0.7",
    "validator": "^13.15.35",
    "vitest": "^4.1.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "resolutions": {
    "happy-dom": "^20.0.8",
    "esbuild": "^0.25.11",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "tmp": "^0.2.5"
  },
  "overrides": {

    "vite": "^7.3.2",
    "yaml": "^1.10.3",
    "flatted": "^3.4.0",
    "postcss": "^8.5.10",
    "fast-uri": "^3.1.2",
    "picomatch": "^2.3.2",
    "hono": "^4.12.18",
    "@hono/node-server": "^1.19.13",
    "fast-xml-builder": "^1.2.0",
    "fast-xml-parser": "^5.7.0",
    "lodash": "^4.18.1"
  }
}
