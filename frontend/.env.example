# Frontend Environment Variables
# Copy this file to .env.local and fill in the actual values

# Public frontend URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Frontend-to-backend proxy configuration
NEXT_PUBLIC_API_BASE_PATH=/api/backend
BACKEND_INTERNAL_URL=http://localhost:3001/api

# Application Configuration
NEXT_PUBLIC_EDUCATION_YEARS=2567

# Legacy fallback only (optional)
# NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Build Analysis (for bundle size analysis during build)
# Set to 'true' to enable bundle analysis, 'false' to disable
ANALYZE=false
