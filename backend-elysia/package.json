{
  "name": "backend-elysia",
  "version": "0.0.1",
  "description": "NKTC Student Management System - Elysia Backend",
  "main": "src/index.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun --minify",
    "start": "bun dist/index.js",
    "prisma:generate": "bun prisma generate",
    "prisma:migrate": "bun prisma migrate dev",
    "prisma:push": "bun prisma db push",
    "postinstall": "bun run prisma:generate"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/client-runtime-utils": "^7.6.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "elysia": "^1.4.28",
    "minio": "^8.0.7",
    "pg": "^8.13.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ua-parser-js": "^2.0.9",
    "uuid": "^11.1.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.9",
    "@types/pg": "^8.11.11",
    "bun-types": "latest",
    "prisma": "^7.5.0",
    "prismabox": "^1.1.26",
    "typescript": "^5.8.2"
  }
}
